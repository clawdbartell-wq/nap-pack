{
  "name": "nap-pack",
  "version": "0.1.0",
  "description": "Single-source-of-truth AEO/SEO directory submission pack generator",
  "type": "module",
  "bin": {
    "nap-pack": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node --format esm",
    "test": "bun test",
    "dev": "bun run src/cli.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": ["aeo", "seo", "directories", "nap", "citations", "submit"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "yaml": "^2.6.0",
    "commander": "^12.1.0"
  }
}